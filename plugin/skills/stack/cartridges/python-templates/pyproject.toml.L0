[project]
requires-python = ">=3.11"

[project.optional-dependencies]
dev = [
  "pytest>=8.0", "pytest-cov>=4.1",
  "mypy>=1.8", "ruff>=0.3",
]

[tool.ruff]
line-length = 100
target-version = "py311"
select = ["E", "F", "I", "N", "UP", "B", "C90"]

[tool.ruff.mccabe]
max-complexity = 10

[tool.mypy]
strict = true

[tool.coverage.report]
fail_under = 95
